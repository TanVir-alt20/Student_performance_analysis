}

descriptive_func(stdata_dtable$AvgScore)

#EDA----------------------
##Mean math score by Gender
stdata_dtable %>% group_by(Gender) %>% 
  summarise(Total = n(), MeanMathScore = mean(Math_score))

##highest Avg score based on parental education level
stdata_dtable %>% group_by(Parent_education_level) %>% 
  summarise(Highest_Avg = max(AvgScore)) %>%  arrange(desc(Highest_Avg))

##compare two colmns
stdata_dtable %>% group_by(Test_prep_course) %>% 
  summarise(
    mean_math = mean(Math_score),
    mean_read = mean(Reading_score),
    mean_write = mean(Writing_score),
    mean_Avg = mean(AvgScore)
  )

##Percenatge passed by gender
table(stdata_dtable$Result)
stdata_dtable %>% group_by(Gender , Result) %>% 
  summarise( Total = n(), meanAVG = mean(AvgScore), .groups = "drop") %>% 
  mutate(Percentage = Total / sum(Total) * 100)

