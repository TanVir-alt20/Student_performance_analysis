#Cleaning------------
##Rename columns removing spaces--------
colnames(stdata_dtable)
library(dplyr)
stdata_dtable <- stdata_dtable %>% rename(Gender = gender, Parent_education_level = `parental level of education`, Test_prep_course = `test preparation course`, Reading_score = `reading score`,
                         Math_score = `math score`,
                         Writing_score = `writing score`,
                         Race = `race/ethnicity`
                         )
str(stdata_dtable)

##Convert all categorical columns to factors----------------
facnames <- c("Gender", "Race", "Parent_education_level", "lunch", "Test_prep_course" )
stdata_dtable <- stdata_dtable %>% 
  mutate(across(facnames, as.factor))
str(stdata_dtable)

##Duplicate row removal------------
sum(duplicated(stdata_dtable)) #no duplicated elements founded


#Transform------------
stdata_dtable <-   stdata_dtable %>% mutate(
  TotalScore = Math_score + Reading_score + Writing_score,
  AvgScore = TotalScore / 3,
  Grade = case_when(
    AvgScore >= 90 ~ "A",
    AvgScore >= 80 ~ "B",
    AvgScore >= 70 ~ "C",
    AvgScore >= 60 ~ "D",
    AvgScore >= 50 ~ "E",
    TRUE ~ "F"),
  Result = if_else(AvgScore >= 50, "Pass", "Fail")
  
  )
