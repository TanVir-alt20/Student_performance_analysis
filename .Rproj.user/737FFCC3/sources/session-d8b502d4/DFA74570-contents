#Database-----------

##Save cleaned data and all summaries into a SQLite database
library(DBI)
library(RSQLite)
db <- dbConnect(drv = SQLite() , ":memory:")
dbListTables(conn = db)
dbWriteTable(conn = db, name = "Student_dta", value = stdata_cleaned)
dbWriteTable(conn = db, name = "Student_summary", value = stdatasummary)
dbListTables(db)

##Query the database to get average math score by gender

dbGetQuery(
  conn = db,
  statement = "SELECT Gender, AVG(Math_score) AS AvgMath
  FROM Student_dta
  GROUP BY Gender"
)
dbDisconnect(db)

